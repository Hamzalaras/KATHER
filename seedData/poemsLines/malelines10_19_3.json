[
  {
    "content": "ما بالُها قد حُسِّنتْ ورقيبُها",
    "type": 1,
    "order": 1,
    "poemId": 15944
  },
  {
    "content": "أبداً قبيحٌ قُبِّح الرقباءُ",
    "type": 2,
    "order": 2,
    "poemId": 15944
  },
  {
    "content": "ما ذاك إلا أنها شمسُ الضحى",
    "type": 1,
    "order": 3,
    "poemId": 15944
  },
  {
    "content": "أبداً تكون رقيبَها الحرباءُ",
    "type": 2,
    "order": 4,
    "poemId": 15944
  },
  {
    "content": "إذا ما المدح سار بلا ثواب",
    "type": 1,
    "order": 1,
    "poemId": 15945
  },
  {
    "content": "من الممدوح فهو لهُ هجاءُ",
    "type": 2,
    "order": 2,
    "poemId": 15945
  },
  {
    "content": "لأن الناس لا يخفى عليهم",
    "type": 1,
    "order": 3,
    "poemId": 15945
  },
  {
    "content": "أمنعٌ كان منهُ أم عطاءُ",
    "type": 2,
    "order": 4,
    "poemId": 15945
  },
  {
    "content": "أحمدُ اللَّه نيةً وثناءَ",
    "type": 1,
    "order": 1,
    "poemId": 15946
  },
  {
    "content": "غُدوةً بل عَشيَّةً بل مساءَ",
    "type": 2,
    "order": 2,
    "poemId": 15946
  },
  {
    "content": "بلْ جميعاً وبين ذلك حمداً",
    "type": 1,
    "order": 3,
    "poemId": 15946
  },
  {
    "content": "أبديّاً يُطبِّقُ الآناءَ",
    "type": 2,
    "order": 4,
    "poemId": 15946
  },
  {
    "content": "حَمْدَ مُستعظمٍ جلالاً عظيماً",
    "type": 1,
    "order": 5,
    "poemId": 15946
  },
  {
    "content": "من مَليكٍ وشاكرٍ آلاءَ",
    "type": 2,
    "order": 6,
    "poemId": 15946
  },
  {
    "content": "مَلِكٌ يقدحُ الحياة من الموْ",
    "type": 1,
    "order": 7,
    "poemId": 15946
  },
  {
    "content": "تى ويَكفي بفضله الأحياءَ",
    "type": 2,
    "order": 8,
    "poemId": 15946
  },
  {
    "content": "صاغنا ثم قاتنا ووَقانا",
    "type": 1,
    "order": 9,
    "poemId": 15946
  },
  {
    "content": "بالتي نتَّقي بها الأَسواءَ",
    "type": 2,
    "order": 10,
    "poemId": 15946
  },
  {
    "content": "من بناءٍ يَكِنُّنا ولَبُوسٍ",
    "type": 1,
    "order": 11,
    "poemId": 15946
  },
  {
    "content": "ودواء يحارب الأدواءَ",
    "type": 2,
    "order": 12,
    "poemId": 15946
  },
  {
    "content": "ثم أهدى لنا الفواكه شتّى",
    "type": 1,
    "order": 13,
    "poemId": 15946
  },
  {
    "content": "والتحياتِ جَلَّ ذاك عطاءَ",
    "type": 2,
    "order": 14,
    "poemId": 15946
  },
  {
    "content": "عَظُمت تلكمُ الأيادي وجَلَّتْ",
    "type": 1,
    "order": 15,
    "poemId": 15946
  },
  {
    "content": "فاذكر المَوز واتركِ الأشياءَ",
    "type": 2,
    "order": 16,
    "poemId": 15946
  },
  {
    "content": "إنما الموزُ حين تُمْكَنُ منهُ",
    "type": 1,
    "order": 17,
    "poemId": 15946
  },
  {
    "content": "كاسمه مبْدلاً من الميم فاءَ",
    "type": 2,
    "order": 18,
    "poemId": 15946
  },
  {
    "content": "وكذا فقدُه العزيزُ علينا",
    "type": 1,
    "order": 19,
    "poemId": 15946
  },
  {
    "content": "كاسمه مبْدلاً من الزاي تاءَ",
    "type": 2,
    "order": 20,
    "poemId": 15946
  },
  {
    "content": "فهو الفوزُ مثلما فقدُهُ المو",
    "type": 1,
    "order": 21,
    "poemId": 15946
  },
  {
    "content": "تُ لقد بان فضلُه لا خَفَاءَ",
    "type": 2,
    "order": 22,
    "poemId": 15946
  },
  {
    "content": "ولهذا التأوِيلِ سَماه موزاً",
    "type": 1,
    "order": 23,
    "poemId": 15946
  },
  {
    "content": "مَنْ أفاد المعانيَ الأسماءَ",
    "type": 2,
    "order": 24,
    "poemId": 15946
  },
  {
    "content": "رَبِّ فاجعله لي صبوحاً وقَيْلاً",
    "type": 1,
    "order": 25,
    "poemId": 15946
  },
  {
    "content": "وغَبوقاً وما أسأت الغذاءَ",
    "type": 2,
    "order": 26,
    "poemId": 15946
  },
  {
    "content": "وأرى بل أبُتُّ أن جوابي",
    "type": 1,
    "order": 27,
    "poemId": 15946
  },
  {
    "content": "لا تُغالط فقد سألتَ البقاءَ",
    "type": 2,
    "order": 28,
    "poemId": 15946
  },
  {
    "content": "يَشهَد اللَّه إنه لطعامٌ",
    "type": 1,
    "order": 29,
    "poemId": 15946
  },
  {
    "content": "خُرَّميٌّ يُغازل الأحشاءَ",
    "type": 2,
    "order": 30,
    "poemId": 15946
  },
  {
    "content": "نكهةٌ عذبةٌ وطعم لذيذٌ",
    "type": 1,
    "order": 31,
    "poemId": 15946
  },
  {
    "content": "سَاعدا نَعمةً إلى نَعْماءَ",
    "type": 2,
    "order": 32,
    "poemId": 15946
  },
  {
    "content": "وتخالُ انْسرابهُ في مجاري",
    "type": 1,
    "order": 33,
    "poemId": 15946
  },
  {
    "content": "هِ افتراعَ الأبكارِ والإغفاءَ",
    "type": 2,
    "order": 34,
    "poemId": 15946
  },
  {
    "content": "لو تكونُ القلوبُ مأوى طعامٍ",
    "type": 1,
    "order": 35,
    "poemId": 15946
  },
  {
    "content": "نازَعتْهُ قلوبُنا الأحشاءَ",
    "type": 2,
    "order": 36,
    "poemId": 15946
  },
  {
    "content": "إنني لَلْحقيق بالشِّبَعِ السا",
    "type": 1,
    "order": 37,
    "poemId": 15946
  },
  {
    "content": "ئغِ من أكلِهِ وإن كان ماءَ",
    "type": 2,
    "order": 38,
    "poemId": 15946
  },
  {
    "content": "مِن عطايا أبي محمدٍ المح",
    "type": 1,
    "order": 39,
    "poemId": 15946
  },
  {
    "content": "مودِ ظَرفاً وحكمةً وسخاءَ",
    "type": 2,
    "order": 40,
    "poemId": 15946
  },
  {
    "content": "وجمالاً مُنَمَّقاً وجلالاً",
    "type": 1,
    "order": 41,
    "poemId": 15946
  },
  {
    "content": "ووفاءً مُحقَّقاً وصفاءَ",
    "type": 2,
    "order": 42,
    "poemId": 15946
  },
  {
    "content": "ذلك السيدُ الذي قتل اليأ",
    "type": 1,
    "order": 43,
    "poemId": 15946
  },
  {
    "content": "سَ بأفضاله وأحيا الرجاءَ",
    "type": 2,
    "order": 44,
    "poemId": 15946
  },
  {
    "content": "سرّني برَّني رعاني كفاني",
    "type": 1,
    "order": 45,
    "poemId": 15946
  },
  {
    "content": "جازَهُ السوءُ إنه ما أساءَ",
    "type": 2,
    "order": 46,
    "poemId": 15946
  },
  {
    "content": "وتخطَّته كلُّ بأساءَ لكن",
    "type": 1,
    "order": 47,
    "poemId": 15946
  },
  {
    "content": "صادمتْ مِن ورائه الأعداءَ",
    "type": 2,
    "order": 48,
    "poemId": 15946
  },
  {
    "content": "وتعالتْ به سماءُ المعالي",
    "type": 1,
    "order": 49,
    "poemId": 15946
  },
  {
    "content": "أو ترى مجدَه السماءُ سماءَ",
    "type": 2,
    "order": 50,
    "poemId": 15946
  },
  {
    "content": "مَلِكاً يَلْبَسُ الطويل من العُم",
    "type": 1,
    "order": 51,
    "poemId": 15946
  },
  {
    "content": "رِ ويَحْظى ويَجْبُرُ الأولياءَ",
    "type": 2,
    "order": 52,
    "poemId": 15946
  },
  {
    "content": "وأما والذي حباني بزُلفا",
    "type": 1,
    "order": 53,
    "poemId": 15946
  },
  {
    "content": "يَ لديه أليَّةً غرَّاءَ",
    "type": 2,
    "order": 54,
    "poemId": 15946
  },
  {
    "content": "لأكدَّنَّ للمدائح فيه",
    "type": 1,
    "order": 55,
    "poemId": 15946
  },
  {
    "content": "فِكَري أو أردَّها أنضاءَ",
    "type": 2,
    "order": 56,
    "poemId": 15946
  },
  {
    "content": "ومَعَاذَ الإله لا مدحَ يأتي",
    "type": 1,
    "order": 57,
    "poemId": 15946
  },
  {
    "content": "فيه كَرْهاً بل مُعفياً إعفاءَ",
    "type": 2,
    "order": 58,
    "poemId": 15946
  },
  {
    "content": "وترانا في مدحهِ كيف كنّا",
    "type": 1,
    "order": 59,
    "poemId": 15946
  },
  {
    "content": "كالمُعَنَّى في أن يُضيء الضياءَ",
    "type": 2,
    "order": 60,
    "poemId": 15946
  },
  {
    "content": "أيُّ مصباح قادحٍ زاد في الإص",
    "type": 1,
    "order": 61,
    "poemId": 15946
  },
  {
    "content": "باح نُوراً إن لم نكن جُهَلاءَ",
    "type": 2,
    "order": 62,
    "poemId": 15946
  },
  {
    "content": "غير أنَّا نُريغُ بالمدح فيه",
    "type": 1,
    "order": 63,
    "poemId": 15946
  },
  {
    "content": "رِفعَةً باسمه لنا وسناءَ",
    "type": 2,
    "order": 64,
    "poemId": 15946
  },
  {
    "content": "رُتَباً لم تَشِد لنا مثلها الآ",
    "type": 1,
    "order": 65,
    "poemId": 15946
  },
  {
    "content": "باءُ نرجو توريثَها الأبناءَ",
    "type": 2,
    "order": 66,
    "poemId": 15946
  },
  {
    "content": "لا عدِمناه ماجداً بلّغ الأب",
    "type": 1,
    "order": 67,
    "poemId": 15946
  },
  {
    "content": "ناء مجداً قد أعجز الآباءَ",
    "type": 2,
    "order": 68,
    "poemId": 15946
  },
  {
    "content": "ليس حمدُ الجفون في مَرْيها النوْ",
    "type": 1,
    "order": 1,
    "poemId": 15947
  },
  {
    "content": "مَ ولا نَفيِها أَذى الأَقذاءِ",
    "type": 2,
    "order": 2,
    "poemId": 15947
  },
  {
    "content": "إنما حمدُها إذا هي حالتْ",
    "type": 1,
    "order": 3,
    "poemId": 15947
  },
  {
    "content": "بين طرفِ العيونِ والبُغَضاءِ",
    "type": 2,
    "order": 4,
    "poemId": 15947
  },
  {
    "content": "المالُ يكسِبُ ربَّه ما لم يَفضْ",
    "type": 1,
    "order": 1,
    "poemId": 15948
  },
  {
    "content": "في الراغبينَ إليه سوءَ ثناءِ",
    "type": 2,
    "order": 2,
    "poemId": 15948
  },
  {
    "content": "كالماءِ تأسِنُ بِئرُهُ إلا إذا",
    "type": 1,
    "order": 3,
    "poemId": 15948
  },
  {
    "content": "خبطَ السُّقاةُ جِمامَهُ بدِلاءِ",
    "type": 2,
    "order": 4,
    "poemId": 15948
  },
  {
    "content": "والنائلُ المُعْطَى بغيرِ وسيلةٍ",
    "type": 1,
    "order": 5,
    "poemId": 15948
  },
  {
    "content": "كالماءِ مُغْتَرفاً بغيرِ رِشاءِ",
    "type": 2,
    "order": 6,
    "poemId": 15948
  },
  {
    "content": "يُهنَّأُ بالإِفطار قومٌ لأنهمْ",
    "type": 1,
    "order": 1,
    "poemId": 15949
  },
  {
    "content": "تأتَّى لهم قبلَ العَشاءِ غَداءُ",
    "type": 2,
    "order": 2,
    "poemId": 15949
  },
  {
    "content": "وأما عليُّ ذو العلا فلأنهُ",
    "type": 1,
    "order": 3,
    "poemId": 15949
  },
  {
    "content": "أطاعَ له الإطعامُ كيف يشاءُ",
    "type": 2,
    "order": 4,
    "poemId": 15949
  },
  {
    "content": "وما فاته في الصومِ فِطْرٌ لأنهٌ",
    "type": 1,
    "order": 5,
    "poemId": 15949
  },
  {
    "content": "مُدارِسُ علمٍ والدِّارسُ غذاءُ",
    "type": 2,
    "order": 6,
    "poemId": 15949
  },
  {
    "content": "ولا فاتهُ في الفطر صومٌ لأنهُ",
    "type": 1,
    "order": 7,
    "poemId": 15949
  },
  {
    "content": "مواصِلُ صومٍ عُقْبَتاهُ سَواءُ",
    "type": 2,
    "order": 8,
    "poemId": 15949
  },
  {
    "content": "هنيئاً له إفطارُهُ وصيامُهُ",
    "type": 1,
    "order": 9,
    "poemId": 15949
  },
  {
    "content": "هنيئاً ومن بعد الهناءِ مَراءُ",
    "type": 2,
    "order": 10,
    "poemId": 15949
  },
  {
    "content": "بحقِّك أمطرتَ الورى وبحقهمْ",
    "type": 1,
    "order": 11,
    "poemId": 15949
  },
  {
    "content": "لأنهُمُ أرضٌ وأنتَ سماءُ",
    "type": 2,
    "order": 12,
    "poemId": 15949
  },
  {
    "content": "وجاهلٍ أعرضتُ عن جهلهِ",
    "type": 1,
    "order": 1,
    "poemId": 15950
  },
  {
    "content": "حتى شكا كفِّي عنِ الشكوى",
    "type": 2,
    "order": 2,
    "poemId": 15950
  },
  {
    "content": "قد هام وجْداً باكْتراثِي له",
    "type": 1,
    "order": 3,
    "poemId": 15950
  },
  {
    "content": "وقد أبتْ نفسيَ ما يهوى",
    "type": 2,
    "order": 4,
    "poemId": 15950
  },
  {
    "content": "إنَّ مِنَ السلوى لخيلولةً",
    "type": 1,
    "order": 5,
    "poemId": 15950
  },
  {
    "content": "تُوهِمني البلوى به بلوى",
    "type": 2,
    "order": 6,
    "poemId": 15950
  },
  {
    "content": "أحضرتُ نجوى النفسِ تمثالَهُ",
    "type": 1,
    "order": 7,
    "poemId": 15950
  },
  {
    "content": "مستَحيِياً من شاهِد النجوى",
    "type": 2,
    "order": 8,
    "poemId": 15950
  },
  {
    "content": "وقلت للشعر أَلا أَعِدْني",
    "type": 1,
    "order": 9,
    "poemId": 15950
  },
  {
    "content": "على طويلِ الغَيِّ مُسْتَهوَى",
    "type": 2,
    "order": 10,
    "poemId": 15950
  },
  {
    "content": "فقال من خاصمتَ مستهلَكٌ",
    "type": 1,
    "order": 11,
    "poemId": 15950
  },
  {
    "content": "ليست على أمثالهِ عَدْوى",
    "type": 2,
    "order": 12,
    "poemId": 15950
  },
  {
    "content": "لو كان لي في مثلهِ موضعٌ",
    "type": 1,
    "order": 13,
    "poemId": 15950
  },
  {
    "content": "غادرتُهُ أُحدوثةً تُروَى",
    "type": 2,
    "order": 14,
    "poemId": 15950
  },
  {
    "content": "بكل بيتٍ سائرٍ عائرٍ",
    "type": 1,
    "order": 15,
    "poemId": 15950
  },
  {
    "content": "يُسمَعُ والوجهُ لهُ يُزوَى",
    "type": 2,
    "order": 16,
    "poemId": 15950
  },
  {
    "content": "لكنّ من تُهدي له شتمَهُ",
    "type": 1,
    "order": 17,
    "poemId": 15950
  },
  {
    "content": "تُهدي إليه المَنَّ والسلوى",
    "type": 2,
    "order": 18,
    "poemId": 15950
  },
  {
    "content": "قوَّمتُهُ بالشتمِ يُهدَى لَهُ",
    "type": 1,
    "order": 19,
    "poemId": 15950
  },
  {
    "content": "فلم أجدْ قيمتَهُ تَسوى",
    "type": 2,
    "order": 20,
    "poemId": 15950
  },
  {
    "content": "لم يَلهُ في المِهْرجانِ أَوْلَى",
    "type": 1,
    "order": 1,
    "poemId": 15951
  },
  {
    "content": "باللهوِ فيه من ابن يحيى",
    "type": 2,
    "order": 2,
    "poemId": 15951
  },
  {
    "content": "لأنه شابَهُ بجودٍ",
    "type": 1,
    "order": 3,
    "poemId": 15951
  },
  {
    "content": "أحيا به الناسَ كلَّ مَحْيا",
    "type": 2,
    "order": 4,
    "poemId": 15951
  },
  {
    "content": "جدَّدَ عهدَ النبيِّ بِرٌّ",
    "type": 1,
    "order": 5,
    "poemId": 15951
  },
  {
    "content": "من ابنِ يحيى وفَضْلُ تقوى",
    "type": 2,
    "order": 6,
    "poemId": 15951
  },
  {
    "content": "وعهدَ كِسْرى نعيمُ عيشٍ",
    "type": 1,
    "order": 7,
    "poemId": 15951
  },
  {
    "content": "من ابن كسرى وحسنُ ملهى",
    "type": 2,
    "order": 8,
    "poemId": 15951
  },
  {
    "content": "فظلَّ في المهرجان عيدٌ",
    "type": 1,
    "order": 9,
    "poemId": 15951
  },
  {
    "content": "يجمعُ ديناً له ودُنيا",
    "type": 2,
    "order": 10,
    "poemId": 15951
  },
  {
    "content": "وليس بِدعاً ولا عجيباً",
    "type": 1,
    "order": 11,
    "poemId": 15951
  },
  {
    "content": "أنْ يَنْظِمَ المعنيين معنى",
    "type": 2,
    "order": 12,
    "poemId": 15951
  },
  {
    "content": "فاللَّهُ يُبقيه ألفَ عامٍ",
    "type": 1,
    "order": 13,
    "poemId": 15951
  },
  {
    "content": "وما رأى في البقاء بُقْيا",
    "type": 2,
    "order": 14,
    "poemId": 15951
  },
  {
    "content": "يَسْمو به جَدُّهُ فيَحْظى",
    "type": 1,
    "order": 15,
    "poemId": 15951
  },
  {
    "content": "وتارةً مجدُه فيَعْلى",
    "type": 2,
    "order": 16,
    "poemId": 15951
  },
  {
    "content": "ولم تزلْ أعينُ الأعادي",
    "type": 1,
    "order": 17,
    "poemId": 15951
  },
  {
    "content": "بنعمة اللَّه فيه تَقْذى",
    "type": 2,
    "order": 18,
    "poemId": 15951
  },
  {
    "content": "يُوقَى بهم أسهمَ المنايا",
    "type": 1,
    "order": 19,
    "poemId": 15951
  },
  {
    "content": "إذا ألمَّتْ به ويُفدى",
    "type": 2,
    "order": 20,
    "poemId": 15951
  },
  {
    "content": "ألم تَرَ لابن بلبلَ إذ حماني",
    "type": 1,
    "order": 1,
    "poemId": 15952
  },
  {
    "content": "مَواردَهُ وأَوْرادِي ظِماءُ",
    "type": 2,
    "order": 2,
    "poemId": 15952
  },
  {
    "content": "سألت الأرضَ تنكيراً عليه",
    "type": 1,
    "order": 3,
    "poemId": 15952
  },
  {
    "content": "فلم تفعلْ فنكَّرتِ السماءُ",
    "type": 2,
    "order": 4,
    "poemId": 15952
  },
  {
    "content": "وصاعدُ ما تَصعَّدَ بل تَهَاوَى",
    "type": 1,
    "order": 5,
    "poemId": 15952
  },
  {
    "content": "ولكنْ جادَ ما صَعِد الدعاءُ",
    "type": 2,
    "order": 6,
    "poemId": 15952
  },
  {
    "content": "رعى هذا الأنامَ فكان ذئباً",
    "type": 1,
    "order": 7,
    "poemId": 15952
  },
  {
    "content": "أحصَّ وما الذئابُ وما الرِّعاءُ",
    "type": 2,
    "order": 8,
    "poemId": 15952
  },
  {
    "content": "أُحبُّ المِهْرَجانَ لأنَّ فيهِ",
    "type": 1,
    "order": 1,
    "poemId": 15953
  },
  {
    "content": "سروراً للملوكِ ذوي السَناءِ",
    "type": 2,
    "order": 2,
    "poemId": 15953
  },
  {
    "content": "وباباً للمصير إلى أوانٍ",
    "type": 1,
    "order": 3,
    "poemId": 15953
  },
  {
    "content": "تُفتَّح فيه أبوابُ السماءِ",
    "type": 2,
    "order": 4,
    "poemId": 15953
  },
  {
    "content": "أُشبِّههُ إذا أَفضَى حميداً",
    "type": 1,
    "order": 5,
    "poemId": 15953
  },
  {
    "content": "بإفضاءِ المَصيفِ إلى الشتاءِ",
    "type": 2,
    "order": 6,
    "poemId": 15953
  },
  {
    "content": "رجاءَ مؤمِّليكَ إذا تناهَى",
    "type": 1,
    "order": 7,
    "poemId": 15953
  },
  {
    "content": "بهم بعد البلاءِ إلى الرخاءِ",
    "type": 2,
    "order": 8,
    "poemId": 15953
  },
  {
    "content": "فَمَهرِجْ فيه تحت ظلال عيشٍ",
    "type": 1,
    "order": 9,
    "poemId": 15953
  },
  {
    "content": "ممدَّدةٍ على عيشٍ فضاءِ",
    "type": 2,
    "order": 10,
    "poemId": 15953
  },
  {
    "content": "أخا نِعَمٍ تتمُّ بلا فناءٍ",
    "type": 1,
    "order": 11,
    "poemId": 15953
  },
  {
    "content": "إذا كان التمامُ أخا الفناءِ",
    "type": 2,
    "order": 12,
    "poemId": 15953
  },
  {
    "content": "يزيدُ اللَّه فيها كلَّ يومٍ",
    "type": 1,
    "order": 13,
    "poemId": 15953
  },
  {
    "content": "فلا تنفكُّ دائمةَ النَّماءِ",
    "type": 2,
    "order": 14,
    "poemId": 15953
  },
  {
    "content": "ويُصْحبُك الإلهُ على الأَعادي",
    "type": 1,
    "order": 15,
    "poemId": 15953
  },
  {
    "content": "مساعدةَ المَقادرِ والقضاءِ",
    "type": 2,
    "order": 16,
    "poemId": 15953
  },
  {
    "content": "شهدتُ لقد لهوتَ وأنت عفُّ",
    "type": 1,
    "order": 17,
    "poemId": 15953
  },
  {
    "content": "مصونُ الدِّين مبذولُ العطاءِ",
    "type": 2,
    "order": 18,
    "poemId": 15953
  },
  {
    "content": "تَغَنَّتك القيانُ فما تغنَّتْ",
    "type": 1,
    "order": 19,
    "poemId": 15953
  },
  {
    "content": "سوى محمولِ مدحِك من غِناءِ",
    "type": 2,
    "order": 20,
    "poemId": 15953
  },
  {
    "content": "وأحسَنُ ما تغنّاك المغنِّي",
    "type": 1,
    "order": 21,
    "poemId": 15953
  },
  {
    "content": "غناءٌ صاغَهُ لك من ثناءِ",
    "type": 2,
    "order": 22,
    "poemId": 15953
  },
  {
    "content": "كَمُلْتَ فلستُ أسألُ فيك شيئاً",
    "type": 1,
    "order": 23,
    "poemId": 15953
  },
  {
    "content": "يَزيدُكَهُ المَليكُ سوى البقاءِ",
    "type": 2,
    "order": 24,
    "poemId": 15953
  },
  {
    "content": "وبعدُ فإنّ عذري في قصوري",
    "type": 1,
    "order": 25,
    "poemId": 15953
  },
  {
    "content": "عن الباب المحجَّب ذي البهاءِ",
    "type": 2,
    "order": 26,
    "poemId": 15953
  },
  {
    "content": "حدوثُ حوادثٍ منها حريقٌ",
    "type": 1,
    "order": 27,
    "poemId": 15953
  },
  {
    "content": "تَحيَّف ما جمعت من الثراءِ",
    "type": 2,
    "order": 28,
    "poemId": 15953
  },
  {
    "content": "فلم أسألْ له خَلَفاً ولكنْ",
    "type": 1,
    "order": 29,
    "poemId": 15953
  },
  {
    "content": "دعوتُ اللَّه مجتهدَ الدعاءِ",
    "type": 2,
    "order": 30,
    "poemId": 15953
  },
  {
    "content": "ليجعَلَه فداءَك إنْ رآه",
    "type": 1,
    "order": 31,
    "poemId": 15953
  },
  {
    "content": "فداءك أيها الغالي الفداءِ",
    "type": 2,
    "order": 32,
    "poemId": 15953
  },
  {
    "content": "وأما قبلَ ذاك فلم يكن لي",
    "type": 1,
    "order": 33,
    "poemId": 15953
  },
  {
    "content": "قَرارٌ في الصباح ولا المساءِ",
    "type": 2,
    "order": 34,
    "poemId": 15953
  },
  {
    "content": "أعاني ضيعةً ما زلتُ منها",
    "type": 1,
    "order": 35,
    "poemId": 15953
  },
  {
    "content": "بِحمدِ اللَّه قِدْماً في عناءِ",
    "type": 2,
    "order": 36,
    "poemId": 15953
  },
  {
    "content": "فرأيَك مُنعِماً بالصفحِ عنِّي",
    "type": 1,
    "order": 37,
    "poemId": 15953
  },
  {
    "content": "فما لي غيرَ صفحِك من عَزاءِ",
    "type": 2,
    "order": 38,
    "poemId": 15953
  },
  {
    "content": "ولا تعتب عليَّ فداك أهلي",
    "type": 1,
    "order": 39,
    "poemId": 15953
  },
  {
    "content": "فتُضعِفَ ما لقيتُ من البلاءِ",
    "type": 2,
    "order": 40,
    "poemId": 15953
  },
  {
    "content": "لولا فواكهُ أَيلولٍ إذا اجتمعتْ",
    "type": 1,
    "order": 1,
    "poemId": 15954
  },
  {
    "content": "من كل نوعٍ ورَقَّ الجوُّ والماءُ",
    "type": 2,
    "order": 2,
    "poemId": 15954
  },
  {
    "content": "إذاَ لَمَا حَفَلتْ نفسي متى اشتملتْ",
    "type": 1,
    "order": 3,
    "poemId": 15954
  },
  {
    "content": "عليَّ هائلةُ الجالَيْن غبراءُ",
    "type": 2,
    "order": 4,
    "poemId": 15954
  },
  {
    "content": "يا حَبَّذَا ليلُ أيلولٍ إذا بردتْ",
    "type": 1,
    "order": 5,
    "poemId": 15954
  },
  {
    "content": "فيه مَضاجِعُنا والريحُ سَجْواءُ",
    "type": 2,
    "order": 6,
    "poemId": 15954
  },
  {
    "content": "وجَمَّش القُرُّ فيه الجلدَ فائتلفتْ",
    "type": 1,
    "order": 7,
    "poemId": 15954
  },
  {
    "content": "من الضَّجيعينِ أحشاءٌ وأحشاءُ",
    "type": 2,
    "order": 8,
    "poemId": 15954
  },
  {
    "content": "وأَسفر القمرُ الساري فصفحتُه",
    "type": 1,
    "order": 9,
    "poemId": 15954
  },
  {
    "content": "ريَّا لها من صفاءِ الجوِّ لألاءُ",
    "type": 2,
    "order": 10,
    "poemId": 15954
  },
  {
    "content": "يا حبذا نفحة من ريحهِ سَحَراً",
    "type": 1,
    "order": 11,
    "poemId": 15954
  },
  {
    "content": "تأتيك فيها من الريحان أنباءُ",
    "type": 2,
    "order": 12,
    "poemId": 15954
  },
  {
    "content": "قلْ فيه ما شئتَ من شهرٍ تعهَّدُهُ",
    "type": 1,
    "order": 13,
    "poemId": 15954
  },
  {
    "content": "في كلّ يومٍ يدٌ للَّهِ بيضاءُ",
    "type": 2,
    "order": 14,
    "poemId": 15954
  }
]