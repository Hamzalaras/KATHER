[
  {
    "content": "فدع مديحي ومدح الناس كلهم",
    "type": 1,
    "order": 1,
    "poemId": 33281
  },
  {
    "content": "والزم مديحاً له الرحمن أولاه",
    "type": 2,
    "order": 2,
    "poemId": 33281
  },
  {
    "content": "فكل من رام مدحاً فيه منحصر",
    "type": 1,
    "order": 3,
    "poemId": 33281
  },
  {
    "content": "لسانه عن يسير من مزاياه",
    "type": 2,
    "order": 4,
    "poemId": 33281
  },
  {
    "content": "",
    "type": 1,
    "order": 5,
    "poemId": 33281
  },
  {
    "content": "ولقد تسابقت السماء وأرضها",
    "type": 1,
    "order": 1,
    "poemId": 33282
  },
  {
    "content": "في ضم شخصك مجمع التبيين",
    "type": 2,
    "order": 2,
    "poemId": 33282
  },
  {
    "content": "ققسمت بينما فروحك في السما",
    "type": 1,
    "order": 3,
    "poemId": 33282
  },
  {
    "content": "والجسم في الأرضين للتحصين",
    "type": 2,
    "order": 4,
    "poemId": 33282
  },
  {
    "content": "يا من قضى الإسلام لما أن قضى",
    "type": 1,
    "order": 1,
    "poemId": 33283
  },
  {
    "content": "لا كان يومك في قضايا كوني",
    "type": 2,
    "order": 2,
    "poemId": 33283
  },
  {
    "content": "إن يمس شخصك في اللحود مغيباً",
    "type": 1,
    "order": 3,
    "poemId": 33283
  },
  {
    "content": "فالعلم فينا منك غير دفين",
    "type": 2,
    "order": 4,
    "poemId": 33283
  },
  {
    "content": "فاذهب جميل الذكر منشور اللوا",
    "type": 1,
    "order": 5,
    "poemId": 33283
  },
  {
    "content": "وإليك في الجنات خير قرين",
    "type": 2,
    "order": 6,
    "poemId": 33283
  },
  {
    "content": "وعليك تترى رحمة الباري متى",
    "type": 1,
    "order": 7,
    "poemId": 33283
  },
  {
    "content": "ما رنحت ريح اللاصبا بغصون",
    "type": 2,
    "order": 8,
    "poemId": 33283
  },
  {
    "content": "الحق نور عليه للهدى علم",
    "type": 1,
    "order": 1,
    "poemId": 33284
  },
  {
    "content": "من أمه متنيراً قاده العلم",
    "type": 2,
    "order": 2,
    "poemId": 33284
  },
  {
    "content": "يا حبذا عترة بدء الوجود بهم",
    "type": 1,
    "order": 3,
    "poemId": 33284
  },
  {
    "content": "وهكذا بهم ينهى ويختتم",
    "type": 2,
    "order": 4,
    "poemId": 33284
  },
  {
    "content": "من مثلهم ورسول اللَه فاتحهم",
    "type": 1,
    "order": 5,
    "poemId": 33284
  },
  {
    "content": "وسيطة العقد والمهدي ختمهم",
    "type": 2,
    "order": 6,
    "poemId": 33284
  },
  {
    "content": "وهل أمية لا لمت بمغفرةٍ",
    "type": 1,
    "order": 7,
    "poemId": 33284
  },
  {
    "content": "ولا نحت سواحها من رحمة ديم",
    "type": 2,
    "order": 8,
    "poemId": 33284
  },
  {
    "content": "تنوش هدب ذيول للهدى سدلت",
    "type": 1,
    "order": 9,
    "poemId": 33284
  },
  {
    "content": "من الإله لها الأملاك تحترم",
    "type": 2,
    "order": 10,
    "poemId": 33284
  },
  {
    "content": "ولا كمثل بني العباس لا رقبوا",
    "type": 1,
    "order": 11,
    "poemId": 33284
  },
  {
    "content": "إلا ولا ذمة بل رحمهم جذموا",
    "type": 2,
    "order": 12,
    "poemId": 33284
  },
  {
    "content": "جنوا بمثل الذي تجني أمية بل",
    "type": 1,
    "order": 13,
    "poemId": 33284
  },
  {
    "content": "على طنابيرهم زادت لهم نغم",
    "type": 2,
    "order": 14,
    "poemId": 33284
  },
  {
    "content": "للَّه سهم سددته يد القضا",
    "type": 1,
    "order": 1,
    "poemId": 33285
  },
  {
    "content": "فأصاب كل الخلق حتى من مضى",
    "type": 2,
    "order": 2,
    "poemId": 33285
  },
  {
    "content": "عقدت عليه المكرمات نطاقها",
    "type": 1,
    "order": 3,
    "poemId": 33285
  },
  {
    "content": "فالآن حق لعقدها أن ينقضها",
    "type": 2,
    "order": 4,
    "poemId": 33285
  },
  {
    "content": "تاللَه أن المرتضى قد شب في قلب",
    "type": 1,
    "order": 5,
    "poemId": 33285
  },
  {
    "content": "الورى لما مضى نار الغضا",
    "type": 2,
    "order": 6,
    "poemId": 33285
  },
  {
    "content": "وسقى ضريح المرتضى صوب الرضا",
    "type": 1,
    "order": 7,
    "poemId": 33285
  },
  {
    "content": "ما نور مفخره على الدنيا أضا",
    "type": 2,
    "order": 8,
    "poemId": 33285
  },
  {
    "content": "على التقى أسس هذا البنا",
    "type": 1,
    "order": 1,
    "poemId": 33286
  },
  {
    "content": "فصار للناس به مأنس",
    "type": 2,
    "order": 2,
    "poemId": 33286
  },
  {
    "content": "عمر بالذكر وفي طاعةٍ",
    "type": 1,
    "order": 3,
    "poemId": 33286
  },
  {
    "content": "تطيب من رؤيته الأنفس",
    "type": 2,
    "order": 4,
    "poemId": 33286
  },
  {
    "content": "نادى به تأريخ إكماله",
    "type": 1,
    "order": 5,
    "poemId": 33286
  },
  {
    "content": "يا مسجداً بالذكر قد أسسوا",
    "type": 2,
    "order": 6,
    "poemId": 33286
  },
  {
    "content": "فقم بلغ السيل الزبي وعلا الربى",
    "type": 1,
    "order": 1,
    "poemId": 33287
  },
  {
    "content": "وصاد وقاد الأرنب الأسد الضاري",
    "type": 2,
    "order": 2,
    "poemId": 33287
  },
  {
    "content": "قفوت بها إثر البهائي وجعفر",
    "type": 1,
    "order": 3,
    "poemId": 33287
  },
  {
    "content": "وكل بمقدار اقتداري له جار",
    "type": 2,
    "order": 4,
    "poemId": 33287
  },
  {
    "content": "سقى عارض الأنوا بوطفاء مدرار",
    "type": 1,
    "order": 1,
    "poemId": 33288
  },
  {
    "content": "معاهد يهدي من شذا طيبها الساري",
    "type": 2,
    "order": 2,
    "poemId": 33288
  },
  {
    "content": "ولا برحت أيدي اللوافح غضةً",
    "type": 1,
    "order": 3,
    "poemId": 33288
  },
  {
    "content": "توشي بروداً من رباها بأزهار",
    "type": 2,
    "order": 4,
    "poemId": 33288
  },
  {
    "content": "ذا مبتداً صدر بالنفي في الـ",
    "type": 1,
    "order": 1,
    "poemId": 33289
  },
  {
    "content": "ـمعنى فألجاه لحذف الخبر",
    "type": 2,
    "order": 2,
    "poemId": 33289
  },
  {
    "content": "وكان فيه فاعل قد غنى",
    "type": 1,
    "order": 3,
    "poemId": 33289
  },
  {
    "content": "عنه كما جاء ببعض الصور",
    "type": 2,
    "order": 4,
    "poemId": 33289
  },
  {
    "content": "تقول غير ضاربٍ عبدنا",
    "type": 1,
    "order": 5,
    "poemId": 33289
  },
  {
    "content": "عبدكم أو غير معطي عمر",
    "type": 2,
    "order": 6,
    "poemId": 33289
  },
  {
    "content": "يا من ببحر النحو يجني الدررا",
    "type": 1,
    "order": 1,
    "poemId": 33290
  },
  {
    "content": "ما مبتداً ليس له من خبر",
    "type": 2,
    "order": 2,
    "poemId": 33290
  },
  {
    "content": "وليس وصفاً لفظه نفي بلا",
    "type": 1,
    "order": 3,
    "poemId": 33290
  },
  {
    "content": "ولا بالاستفهام شاب الخير",
    "type": 2,
    "order": 4,
    "poemId": 33290
  },
  {
    "content": "يا فاعل الخير والإحسان مجتهداً",
    "type": 1,
    "order": 1,
    "poemId": 33291
  },
  {
    "content": "أنفق ولا تخش من ذي العرش أقتارا",
    "type": 2,
    "order": 2,
    "poemId": 33291
  },
  {
    "content": "فاللَه يجزيك أضعافاً مضاعفةً",
    "type": 1,
    "order": 3,
    "poemId": 33291
  },
  {
    "content": "والرزق يأتيك آصالاً وأبكارا",
    "type": 2,
    "order": 4,
    "poemId": 33291
  },
  {
    "content": "أيا علماء العصر هل من مخبر",
    "type": 1,
    "order": 1,
    "poemId": 33292
  },
  {
    "content": "عن امرأة حلت لصاحبها عقدا",
    "type": 2,
    "order": 2,
    "poemId": 33292
  },
  {
    "content": "فإن طلقت قبل الدخول ففرضها",
    "type": 1,
    "order": 3,
    "poemId": 33292
  },
  {
    "content": "ثلاثة أقراء تعد لها عدا",
    "type": 2,
    "order": 4,
    "poemId": 33292
  },
  {
    "content": "وإن طلقت بعد الدخول ففرضها",
    "type": 1,
    "order": 5,
    "poemId": 33292
  },
  {
    "content": "بقرء من الأقراء تأتي به فردا",
    "type": 2,
    "order": 6,
    "poemId": 33292
  },
  {
    "content": "يا سائلاً لم يجب",
    "type": 1,
    "order": 1,
    "poemId": 33293
  },
  {
    "content": "عن لغز مستغرب",
    "type": 2,
    "order": 2,
    "poemId": 33293
  },
  {
    "content": "ذاك مريض مطلقاً",
    "type": 1,
    "order": 3,
    "poemId": 33293
  },
  {
    "content": "زوجته على تقى",
    "type": 2,
    "order": 4,
    "poemId": 33293
  },
  {
    "content": "أو ضرر أو مطلقاً",
    "type": 1,
    "order": 5,
    "poemId": 33293
  },
  {
    "content": "على خلاف حققا",
    "type": 2,
    "order": 6,
    "poemId": 33293
  },
  {
    "content": "فمات في هذا المرض",
    "type": 1,
    "order": 7,
    "poemId": 33293
  },
  {
    "content": "لا مرض به عرض",
    "type": 2,
    "order": 8,
    "poemId": 33293
  },
  {
    "content": "بعد تمام العده",
    "type": 1,
    "order": 9,
    "poemId": 33293
  },
  {
    "content": "ولم تزوج بعده",
    "type": 2,
    "order": 10,
    "poemId": 33293
  },
  {
    "content": "وهي تمام الحول",
    "type": 1,
    "order": 11,
    "poemId": 33293
  },
  {
    "content": "فاقنع بهذا القول",
    "type": 2,
    "order": 12,
    "poemId": 33293
  },
  {
    "content": "يا فضلاء الأدب",
    "type": 1,
    "order": 1,
    "poemId": 33294
  },
  {
    "content": "من عجم أو عرب",
    "type": 2,
    "order": 2,
    "poemId": 33294
  },
  {
    "content": "ما قولكم في أجنبي",
    "type": 1,
    "order": 3,
    "poemId": 33294
  },
  {
    "content": "مورث من أجنبي",
    "type": 2,
    "order": 4,
    "poemId": 33294
  },
  {
    "content": "حال وجود أقرب",
    "type": 1,
    "order": 5,
    "poemId": 33294
  },
  {
    "content": "ذي نسب لم يحجب",
    "type": 2,
    "order": 6,
    "poemId": 33294
  },
  {
    "content": "طرقت نفيسة والدجى لم ينجل",
    "type": 1,
    "order": 1,
    "poemId": 33295
  },
  {
    "content": "فاهيم منها في هواي بهولة",
    "type": 2,
    "order": 2,
    "poemId": 33295
  },
  {
    "content": "جملاء في أنف الشباب الأجمل",
    "type": 1,
    "order": 3,
    "poemId": 33295
  },
  {
    "content": "خرعوبة رعوبةب بهنانة",
    "type": 2,
    "order": 4,
    "poemId": 33295
  },
  {
    "content": "وهناتة نفج الحقيبة عيطل",
    "type": 1,
    "order": 5,
    "poemId": 33295
  },
  {
    "content": "رود بخنداة رداح خدلة",
    "type": 2,
    "order": 6,
    "poemId": 33295
  },
  {
    "content": "خود برخداة اناة عطبل",
    "type": 1,
    "order": 7,
    "poemId": 33295
  },
  {
    "content": "لعب الهوى بجوانحي وجوارحي",
    "type": 2,
    "order": 8,
    "poemId": 33295
  },
  {
    "content": "ما بين مبتسم لها ومقبل",
    "type": 1,
    "order": 9,
    "poemId": 33295
  },
  {
    "content": "فيها شفاء الصب من برحائه",
    "type": 2,
    "order": 10,
    "poemId": 33295
  },
  {
    "content": "وحياة قلب بالغرام مقتل",
    "type": 1,
    "order": 11,
    "poemId": 33295
  },
  {
    "content": "هيهات شهد النحل من صلوانه",
    "type": 2,
    "order": 12,
    "poemId": 33295
  },
  {
    "content": "والمسك من عرف له متعلل",
    "type": 1,
    "order": 13,
    "poemId": 33295
  },
  {
    "content": "يا طيبه للصب لو جادت به",
    "type": 2,
    "order": 14,
    "poemId": 33295
  },
  {
    "content": "أو نولته الصب بعض منول",
    "type": 1,
    "order": 15,
    "poemId": 33295
  },
  {
    "content": "فلطالما ولطالما بخلت به",
    "type": 2,
    "order": 16,
    "poemId": 33295
  },
  {
    "content": "ولقلما ولقلما لم تبخل",
    "type": 1,
    "order": 17,
    "poemId": 33295
  },
  {
    "content": "يا حبذا ما نولته وحبذا",
    "type": 2,
    "order": 18,
    "poemId": 33295
  },
  {
    "content": "ما لم تنول من عطاء مقلل",
    "type": 1,
    "order": 19,
    "poemId": 33295
  },
  {
    "content": "ولنعم ما سمحت وما شحت به",
    "type": 2,
    "order": 20,
    "poemId": 33295
  },
  {
    "content": "ولنعم ما بذلت وما لم تبذل",
    "type": 1,
    "order": 21,
    "poemId": 33295
  },
  {
    "content": "ولحبذا هي من حبيب مجزع",
    "type": 2,
    "order": 22,
    "poemId": 33295
  },
  {
    "content": "ولحبذا هي من حبيب مجذل",
    "type": 1,
    "order": 23,
    "poemId": 33295
  },
  {
    "content": "تلكم كناتة من قريش سادة",
    "type": 2,
    "order": 24,
    "poemId": 33295
  },
  {
    "content": "من صخرة اللّه التي لم تنكل",
    "type": 1,
    "order": 25,
    "poemId": 33295
  },
  {
    "content": "شهد النبي لها بهذا معلنا",
    "type": 2,
    "order": 26,
    "poemId": 33295
  },
  {
    "content": "خبرا صحيحا لا يرام لمبطل",
    "type": 1,
    "order": 27,
    "poemId": 33295
  },
  {
    "content": "فرع الكرام بنو الكرام ذووهم",
    "type": 2,
    "order": 28,
    "poemId": 33295
  },
  {
    "content": "من كل أروع زول قوم مزيل",
    "type": 1,
    "order": 29,
    "poemId": 33295
  }
]